# Build output
**/bin/
**/obj/

# Version control
.git/
.github/

# Visual Studio / Rider artefacts
**/*.user
.vs/
**/.idea/
**/*.suo
**/*.rsuser

# Logs produced at runtime — never bake into the image
**/logs/

# SQLite databases — runtime data, not part of the image
**/*.db
**/*.db-shm
**/*.db-wal

# Node / front-end tooling (if added later)
node_modules/

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose*.yml
.dockerignore
