{
  "ConnectionStrings": {
    "DefaultConnection": "#{SQL_CONNECTION_STRING}#"
  },
  "JwtSettings": {
    "SecretKey": "#{JWT_SECRET_KEY}#",
    "Issuer": "HouseBudgetAPI",
    "Audience": "HouseBudgetClient",
    "ExpirationHours": 1
  },
  "EmailSettings": {
    "SmtpHost": "#{SMTP_HOST}#",
    "SmtpPort": "587",
    "SmtpUser": "#{SMTP_USER}#",
    "SmtpPassword": "#{SMTP_PASSWORD}#",
    "FromEmail": "#{FROM_EMAIL}#",
    "FromName": "HouseBudget"
  },
  "Stripe": {
    "PublishableKey": "#{STRIPE_PUBLISHABLE_KEY}#",
    "SecretKey": "#{STRIPE_SECRET_KEY}#",
    "WebhookSecret": "#{STRIPE_WEBHOOK_SECRET}#"
  },
  "Cors": {
    "AllowedOrigins": [ "#{ALLOWED_ORIGINS}#" ]
  },
  "RateLimiting": {
    "LoginWindowSeconds": 60,
    "LoginMaxAttempts": 10,
    "GlobalWindowSeconds": 60,
    "GlobalMaxRequests": 300
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
