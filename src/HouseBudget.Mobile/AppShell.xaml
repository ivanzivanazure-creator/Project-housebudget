<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="HouseBudget.Mobile.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:HouseBudget.Mobile.Views"
       Shell.FlyoutBehavior="Disabled">

    <!-- Auth -->
    <ShellContent Route="login" ContentTemplate="{DataTemplate views:LoginPage}" Shell.NavBarIsVisible="False" />

    <!-- Main Tabs -->
    <TabBar Route="main">
        <Tab Title="Dashboard" Icon="dashboard.png">
            <ShellContent Route="dashboard" ContentTemplate="{DataTemplate views:DashboardPage}" />
        </Tab>
        <Tab Title="Transactions" Icon="transactions.png">
            <ShellContent Route="transactions" ContentTemplate="{DataTemplate views:TransactionsPage}" />
        </Tab>
        <Tab Title="Budgets" Icon="budget.png">
            <ShellContent Route="budgets" ContentTemplate="{DataTemplate views:BudgetsPage}" />
        </Tab>
        <Tab Title="Goals" Icon="goals.png">
            <ShellContent Route="goals" ContentTemplate="{DataTemplate views:GoalsPage}" />
        </Tab>
        <Tab Title="Bills" Icon="bills.png">
            <ShellContent Route="bills" ContentTemplate="{DataTemplate views:BillsPage}" />
        </Tab>
        <Tab Title="Reports" Icon="reports.png">
            <ShellContent Route="reports" ContentTemplate="{DataTemplate views:ReportsPage}" />
        </Tab>
        <Tab Title="Premium" Icon="subscription.png">
            <ShellContent Route="subscription" ContentTemplate="{DataTemplate views:SubscriptionPage}" />
        </Tab>
        <Tab Title="Profile" Icon="profile.png">
            <ShellContent Route="profile" ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>

</Shell>
