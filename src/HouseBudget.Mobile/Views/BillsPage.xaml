<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="HouseBudget.Mobile.Views.BillsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HouseBudget.Mobile.ViewModels"
             x:DataType="vm:BillsViewModel"
             Title="Bills"
             BackgroundColor="#F5F7FA">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Bills Summary Header -->
        <Frame Grid.Row="0" BackgroundColor="#1A1A2E" CornerRadius="0" Padding="16" HasShadow="False">
            <Grid ColumnDefinitions="*,*">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label Text="Monthly Total" FontSize="12" TextColor="#90A4AE" HorizontalOptions="Center" />
                    <Label Text="{Binding TotalMonthlyAmount, StringFormat='{0:N2}'}"
                           FontSize="22" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label Text="Due Soon" FontSize="12" TextColor="#90A4AE" HorizontalOptions="Center" />
                    <Label Text="{Binding DueSoonCount, StringFormat='{0} bill(s)'}"
                           FontSize="22" FontAttributes="Bold" TextColor="#FF9800" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <!-- Add Bill Button -->
        <Button Grid.Row="1" Text="+ Add Bill" Command="{Binding CreateBillCommand}"
                BackgroundColor="#E94560" TextColor="White" CornerRadius="8" Margin="16,12"
                FontAttributes="Bold" HeightRequest="44" />

        <!-- Bills List -->
        <RefreshView Grid.Row="2" Command="{Binding LoadBillsCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Bills}" Margin="16,0">
                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12" Margin="0,40">
                        <Label Text="🧾" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="No bills added yet" FontSize="16" TextColor="#90A4AE" HorizontalOptions="Center" />
                        <Label Text="Tap '+ Add Bill' to track recurring bills" FontSize="13" TextColor="#B0BEC5" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" CornerRadius="16" Padding="16" Margin="0,0,0,12" HasShadow="True">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

                                <!-- Color dot -->
                                <Frame Grid.Column="0" Grid.RowSpan="2"
                                       WidthRequest="44" HeightRequest="44" CornerRadius="22"
                                       BackgroundColor="{Binding Color}" Padding="0" HasShadow="False"
                                       VerticalOptions="Center" Margin="0,0,12,0">
                                    <Label Text="📅" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Frame>

                                <!-- Bill name + recurrence -->
                                <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="2">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#1A1A2E" />
                                    <Label Text="{Binding RecurrenceName}" FontSize="12" TextColor="#90A4AE" />
                                </VerticalStackLayout>

                                <!-- Amount -->
                                <VerticalStackLayout Grid.Column="2" Grid.Row="0" HorizontalOptions="End" Spacing="4">
                                    <Label FontSize="16" FontAttributes="Bold" TextColor="#1A1A2E" HorizontalOptions="End">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Amount, StringFormat='{0:N2}'}" />
                                                <Span Text=" " />
                                                <Span Text="{Binding Currency}" FontSize="12" TextColor="#90A4AE" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>

                                <!-- Due date badge + Mark Paid button -->
                                <HorizontalStackLayout Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                                                       Spacing="8" Margin="0,8,0,0">

                                    <!-- Overdue badge -->
                                    <Frame IsVisible="{Binding IsOverdue}"
                                           BackgroundColor="#FFEBEE" Padding="8,3" CornerRadius="6" HasShadow="False">
                                        <Label Text="{Binding NextDueDate, StringFormat='Overdue: {0:MMM d}'}"
                                               FontSize="11" FontAttributes="Bold" TextColor="#C62828" />
                                    </Frame>

                                    <!-- Due soon badge -->
                                    <Frame IsVisible="{Binding IsDueSoon}"
                                           BackgroundColor="#FFF3E0" Padding="8,3" CornerRadius="6" HasShadow="False">
                                        <Label Text="{Binding NextDueDate, StringFormat='Due: {0:MMM d}'}"
                                               FontSize="11" FontAttributes="Bold" TextColor="#E65100" />
                                    </Frame>

                                    <!-- Normal due date -->
                                    <Frame BackgroundColor="#E8F5E9" Padding="8,3" CornerRadius="6" HasShadow="False">
                                        <Label Text="{Binding NextDueDate, StringFormat='Due: {0:MMM d}'}"
                                               FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" />
                                    </Frame>

                                    <Button Text="Mark Paid"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BillsViewModel}}, Path=MarkPaidCommand}"
                                            CommandParameter="{Binding Id}"
                                            BackgroundColor="#E8F5E9" TextColor="#2E7D32"
                                            FontSize="12" Padding="10,4" CornerRadius="8"
                                            HeightRequest="30" HorizontalOptions="EndAndExpand" />
                                </HorizontalStackLayout>

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
