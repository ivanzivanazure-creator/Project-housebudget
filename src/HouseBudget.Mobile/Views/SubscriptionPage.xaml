<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="HouseBudget.Mobile.Views.SubscriptionPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HouseBudget.Mobile.ViewModels"
             xmlns:models="clr-namespace:HouseBudget.Mobile.Models"
             x:DataType="vm:SubscriptionViewModel"
             Title="Subscription"
             BackgroundColor="#F5F7FA">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header Banner -->
            <Frame BackgroundColor="#1A1A2E" CornerRadius="0" Padding="20,24" HasShadow="False">
                <VerticalStackLayout Spacing="12">

                    <!-- Current Plan (if subscribed) -->
                    <Grid IsVisible="{Binding HasSubscription}" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding CurrentSubscription.PlanName}"
                                   FontSize="22" FontAttributes="Bold" TextColor="White" />
                            <Label Text="{Binding RenewalText}"
                                   FontSize="13" TextColor="#90A4AE" />
                        </VerticalStackLayout>
                        <Frame Grid.Column="1"
                               BackgroundColor="{Binding StatusBadgeColor}"
                               Padding="10,4" CornerRadius="12" HasShadow="False"
                               VerticalOptions="Center">
                            <Label Text="{Binding StatusBadgeText}"
                                   FontSize="12" FontAttributes="Bold" TextColor="White" />
                        </Frame>
                    </Grid>

                    <!-- No Subscription -->
                    <VerticalStackLayout IsVisible="{Binding HasSubscription, Converter={StaticResource InverseBoolConverter}}"
                                        Spacing="6">
                        <Label Text="Upgrade Your Plan"
                               FontSize="22" FontAttributes="Bold" TextColor="White" />
                        <Label Text="Unlock premium features and take control of your finances"
                               FontSize="13" TextColor="#90A4AE" />
                    </VerticalStackLayout>

                    <!-- Current Plan Features Summary -->
                    <Grid IsVisible="{Binding HasSubscription}" ColumnDefinitions="*,*,*" Margin="0,8,0,0">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding CurrentSubscription.Features.MaxAccounts, StringFormat='{0}'}"
                                   FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                            <Label Text="Accounts" FontSize="11" TextColor="#90A4AE" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding CurrentSubscription.Features.MaxBudgets, StringFormat='{0}'}"
                                   FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                            <Label Text="Budgets" FontSize="11" TextColor="#90A4AE" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                            <Label Text="{Binding CurrentSubscription.Features.MaxGoals, StringFormat='{0}'}"
                                   FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                            <Label Text="Goals" FontSize="11" TextColor="#90A4AE" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- Billing Period Toggle -->
            <Frame Margin="16,16,16,0" Padding="4" CornerRadius="12"
                   BackgroundColor="White" HasShadow="False"
                   BorderColor="#E0E0E0">
                <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0" Text="Monthly"
                            Command="{Binding SelectBillingPeriodCommand}"
                            CommandParameter="Monthly"
                            BackgroundColor="{Binding ShowMonthly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#E94560|Transparent'}"
                            TextColor="{Binding ShowMonthly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='White|#1A1A2E'}"
                            CornerRadius="10" HeightRequest="40" FontAttributes="Bold" />
                    <Button Grid.Column="1" Text="Annual (Save 16%)"
                            Command="{Binding SelectBillingPeriodCommand}"
                            CommandParameter="Annual"
                            BackgroundColor="{Binding ShowMonthly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Transparent|#E94560'}"
                            TextColor="{Binding ShowMonthly, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#1A1A2E|White'}"
                            CornerRadius="10" HeightRequest="40" FontAttributes="Bold" />
                </Grid>
            </Frame>

            <!-- Plans -->
            <Label Text="Choose Your Plan" FontSize="18" FontAttributes="Bold"
                   TextColor="#1A1A2E" Margin="16,20,16,8" />

            <CollectionView ItemsSource="{Binding Plans}" Margin="16,0" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SubscriptionPlanModel">
                        <Frame BackgroundColor="White" CornerRadius="16" Padding="20" Margin="0,0,0,12" HasShadow="True">
                            <VerticalStackLayout Spacing="14">

                                <!-- Plan Header -->
                                <HorizontalStackLayout>
                                    <VerticalStackLayout HorizontalOptions="FillAndExpand">
                                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" />
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="#90A4AE" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout HorizontalOptions="End">
                                        <HorizontalStackLayout>
                                            <Label Text="$" FontSize="14" TextColor="#1A1A2E" VerticalOptions="Start" Margin="0,4,0,0" />
                                            <Label Text="{Binding Price, StringFormat='{0:N2}'}" FontSize="26" FontAttributes="Bold" TextColor="#1A1A2E" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding BillingPeriod, StringFormat='per {0}'}" FontSize="11" TextColor="#90A4AE" HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Trial Badge -->
                                <Frame IsVisible="{Binding TrialDays, Converter={StaticResource IntToBoolConverter}}"
                                       BackgroundColor="#E3F2FD" Padding="8,4" CornerRadius="6" HasShadow="False">
                                    <Label Text="{Binding TrialDays, StringFormat='{0}-day free trial'}"
                                           FontSize="12" FontAttributes="Bold" TextColor="#1565C0" />
                                </Frame>

                                <!-- Divider -->
                                <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" />

                                <!-- Features -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Features" FontSize="13" FontAttributes="Bold" TextColor="#607D8B" />

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="{Binding Features.MaxAccounts, StringFormat='{0} accounts'}"
                                               FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="{Binding Features.MaxBudgets, StringFormat='{0} budgets'}"
                                               FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="{Binding Features.MaxGoals, StringFormat='{0} goals'}"
                                               FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout IsVisible="{Binding Features.CanExportData}" Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="Export data (CSV/PDF)" FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout IsVisible="{Binding Features.HasAdvancedReports}" Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="Advanced reports &amp; analytics" FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout IsVisible="{Binding Features.CanAttachReceipts}" Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="Receipt attachments" FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout IsVisible="{Binding Features.HasMultiCurrency}" Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="Multi-currency support" FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout IsVisible="{Binding Features.HasEmailAlerts}" Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="Email alerts &amp; notifications" FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout IsVisible="{Binding Features.HasApiAccess}" Spacing="8">
                                        <Label Text="✓" TextColor="#4CAF50" FontAttributes="Bold" />
                                        <Label Text="API access" FontSize="13" TextColor="#1A1A2E" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Subscribe / Upgrade Button -->
                                <Button Text="{Binding Price, Converter={StaticResource PriceToActionConverter}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SubscriptionViewModel}}, Path=SubscribeCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="{Binding Tier, Converter={StaticResource TierToColorConverter}}"
                                        TextColor="White" CornerRadius="10"
                                        HeightRequest="48" FontAttributes="Bold" FontSize="15" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Cancel Section (only when active) -->
            <Frame IsVisible="{Binding HasSubscription}"
                   BackgroundColor="White" CornerRadius="16" Margin="16,0,16,16"
                   Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Manage Subscription" FontSize="16" FontAttributes="Bold" TextColor="#1A1A2E" />
                    <Label Text="Need to cancel? You can cancel at any time. Your access continues until the end of the current billing period."
                           FontSize="13" TextColor="#607D8B" />
                    <Button Text="Cancel Subscription"
                            Command="{Binding CancelSubscriptionCommand}"
                            BackgroundColor="#FFEBEE" TextColor="#C62828"
                            CornerRadius="10" HeightRequest="44"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Frame>

            <!-- Payment History -->
            <VerticalStackLayout IsVisible="{Binding PaymentHistory.Count, Converter={StaticResource IntToBoolConverter}}"
                                 Margin="16,0,16,32" Spacing="8">
                <Label Text="Payment History" FontSize="16" FontAttributes="Bold" TextColor="#1A1A2E" />
                <CollectionView ItemsSource="{Binding PaymentHistory}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PaymentHistoryItem">
                            <Frame BackgroundColor="White" CornerRadius="12" Padding="16,12"
                                   Margin="0,0,0,8" HasShadow="False" BorderColor="#F0F0F0">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding PlanName}" FontSize="14" FontAttributes="Bold" TextColor="#1A1A2E" />
                                        <Label Text="{Binding InvoiceNumber}" FontSize="11" TextColor="#90A4AE" />
                                        <Label Text="{Binding PaidAt, StringFormat='{0:MMM d, yyyy}'}"
                                               FontSize="11" TextColor="#90A4AE" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                        <Label Text="{Binding Amount, StringFormat='${0:N2}'}"
                                               FontSize="16" FontAttributes="Bold" TextColor="#1A1A2E" HorizontalOptions="End" />
                                        <Frame BackgroundColor="#E8F5E9" Padding="6,2" CornerRadius="6" HasShadow="False">
                                            <Label Text="{Binding StatusName}" FontSize="11" FontAttributes="Bold" TextColor="#2E7D32" />
                                        </Frame>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
